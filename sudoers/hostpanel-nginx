# HostPanel nginx plugin sudoers — installed by package manager on upload
# Removed automatically when the plugin is uninstalled.
# File operations (cp, chmod, chown, mkdir, tee, rm) are covered by core sudoers.

# ── Bundled nginx binary operations ───────────────────────────────────────────
%hostpanel ALL=(root) NOPASSWD: /opt/hostpanel/plugins/nginx/nginx
%hostpanel ALL=(root) NOPASSWD: /opt/hostpanel/plugins/nginx/nginx -t
%hostpanel ALL=(root) NOPASSWD: /opt/hostpanel/plugins/nginx/nginx -s *
